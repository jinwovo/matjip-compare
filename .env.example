# 구글 별점/리뷰수를 함께 보려면 Google Maps Platform의 Places API 키를 넣으세요.
# (선택 사항 — 없으면 네이버·카카오만 표시됩니다. rating/userRatingCount는 유료 SKU입니다.)
# 발급: https://console.cloud.google.com/  →  Places API (New) 사용 설정 → 사용자 인증 정보 → API 키
GOOGLE_MAPS_API_KEY=

# AI 지역 브리핑을 켜려면 Anthropic API 키를 넣으세요.
# (선택 — 없으면 규칙 기반 요약으로 폴백합니다.)
# 발급: https://console.anthropic.com/  →  API Keys
ANTHROPIC_API_KEY=

# 서버 포트 (기본 5178)
PORT=5178
